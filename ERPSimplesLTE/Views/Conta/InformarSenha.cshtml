@model ERPSimplesLTE.Models.Usuario

@{
    Layout = null;
}

@if (TempData["cSenha"] != "")
{
    <script>
        alert('@Html.Raw(TempData["cSenha"])')
    </script>
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AdminLTE 3 | Recover Password (v2)</title>

    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="../adminlte/plugins/fontawesome-free/css/all.min.css">
    <!-- icheck bootstrap -->
    <link rel="stylesheet" href="../adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="../adminlte/css/adminlte.min.css">
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="../adminlte/plugins/sweetalert2-theme-bootstrap-4/bootstrap-4.min.css">
    <!-- Toastr -->
    <link rel="stylesheet" href="../adminlte/plugins/toastr/toastr.min.css">
    <!-- BootStrap-fs-modal -->
    <link rel="stylesheet" href="../adminlte/plugins/bootstrap-fs-modal/css/bootstrap-fs-modal.css">

</head>
<body class="hold-transition login-page">
    <div class="login-box">
        <div class="card card-outline card-primary">
            <div class="card-header text-center">
                <a href="#" class="h1"><b>Admin</b>LTE</a>
            </div>
            <div class="card-body">
                <p class="login-box-msg">Você está a apenas um passo de sua nova senha, recupere sua senha agora.</p>
                <form method="post" onsubmit="javascript: return validaCampos();">
                    <div class="input-group mb-3">
                        <input type="password" class="form-control" placeholder="Digite a senha " name="senha" id="senha" size="12" minlength="6" maxlength="12">
                        <div class="input-group-append">
                            <div class="input-group-text">
                                <span class="fas fa-lock"></span>
                            </div>
                        </div>
                    </div>
                    <div class="input-group mb-3">
                        <input type="password" class="form-control" placeholder="Digite novamente a senha" name="senhaconfirmar" id="senhaconfirmar" size="12" minlength="6" maxlength="12">
                        <div class="input-group-append">
                            <div class="input-group-text">
                                <span class="fas fa-lock"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <button type="submit" id="btnGravarSenha" name="btnGravarSenha" class="btn btn-primary btn-block swalDefaultWarning">Gravar Senha</button>
                        </div>
                        <!-- /.col -->
                    </div>
                </form>

                <p class="mt-3 mb-1">
                    <a href="@Url.Action("Login", "Conta")" class="nav-link active">Login</a>
                </p>
            </div>
            <!-- /.login-card-body -->
        </div>
    </div>

    <!-- FuncoesJS-->
    <script src="../Scripts/FuncoesJS.js"></script>
    <!-- jQuery -->
    <script src="../adminlte/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="../adminlte/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- AdminLTE App -->
    <script src="../adminlte/js/adminlte.min.js"></script>
    <!-- bs-custom-file-input -->
    <script src="../adminlte/plugins/bs-custom-file-input/bs-custom-file-input.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="../adminlte/plugins/sweetalert2/sweetalert2.min.js"></script>
    <!-- Toastr -->
    <script src="../adminlte/plugins/toastr/toastr.min.js"></script>

    <script type="text/javascript">
        debugger
        $(document).ready(function () {
            debugger
            $('#senha').on('change', function () { validaCampos(); });
            $('#senhaconfirmar').on('change', function () { validaCampos(); });
            document.getElementById("senha").focus();
        })

            $('#btnGravarSenha').click(function () {
                debugger

                var valida = validaCampos();
                if (valida == true) {
                    $.ajax({
                        type: "POST",
                        url: '@Url.Content("~/Conta/InformarSenha")',
                        data: { Senha: $('#senha').val(), SenhaConfirmar: $('#senha').val() },
                        async: true,
                        success: function (data) {
                            debugger
                            alert("Senha alterada com sucesso !!!");
                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            alert('errorThrown: ' + errorThrown);
                        }
                    });
                }
                else {
                    document.getElementById('senhaconfirmar').focus();
                    document.getElementById('senhaconfirmar').style.background = "#ff6961";
                    return false; }
        });

        function validaCampos() {
            debugger
            var vSenha = $("#senha").val();
            var vSenhaConfirmar = $("#senhaconfirmar").val();
            var Ok = true;

            document.getElementById('senha').style.background = "#FFFFFF";
            document.getElementById('senhaconfirmar').style.background = "#FFFFFF";

            if (document.getElementById("senha").value.length < 4) {
                document.getElementById('senha').style.background = "#ffc107";
                Ok = false;
            }

            if (document.getElementById("senhaconfirmar").value.length < 4) {
                document.getElementById('senhaconfirmar').style.background = "#ffc107";
                Ok = false;
            }
            else {
                if (vSenha != vSenhaConfirmar) {
                    validaMensagem('As senhas não são iguais.');
                    document.getElementById('senhaconfirmar').style.background = "#dc3545";
                    Ok = false;
                }
            }

            if (Ok == true) { return true; } else { return false; }
        }

    </script>
</body>
</html>

