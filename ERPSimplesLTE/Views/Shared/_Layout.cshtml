@using System.Web.Optimization
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AdminLTE 3 | Starter</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback"> 
    <!-- Ionicons -->
    <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css"> 

@{ 
    string modulos = Request.Url.AbsolutePath.Trim().ToString();
    string Host = Request.Url.Host;
    string verificalocal = string.Empty;
    string localpath = string.Empty;
    string url = "site";
    int nlocal = 0;
    int notIndex = 0;

    if (Host == "localhost")
    { verificalocal = modulos; nlocal = 0; } else { verificalocal = url + modulos; nlocal = 1; }

    if (nlocal == 1) { localpath = "/site"; } else { localpath = "../.."; }

    if (verificalocal.Equals("/Home/Inicio") || verificalocal.Equals("/Home/Contato") || verificalocal.Equals("/Home/Sobre") )
    { notIndex = 1; } else { notIndex = 0; }

    @*@verificalocal;
    <br />
    @modulos;*@

if (modulos == verificalocal && Host == "localhost" && notIndex == 1)
{
        <!-- Tempusdominus Bootstrap 4 -->
        <link rel="stylesheet" href="../adminlte/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css">
         <!-- iCheck -->
         <link rel="stylesheet" href="../adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
         <!-- JQVMap -->
         <link rel="stylesheet" href="../adminlte/plugins/jqvmap/jqvmap.min.css">
         <!-- Theme style -->
         <link rel="stylesheet" href="../adminlte/css/adminlte.min.css">
         <!-- overlayScrollbars -->
         <link rel="stylesheet" href="../adminlte/plugins/overlayScrollbars/css/OverlayScrollbars.min.css">
         <!-- Daterange picker -->
         <link rel="stylesheet" href="../adminlte/plugins/daterangepicker/daterangepicker.css">
         <!-- Summer Note -->
         <link rel="stylesheet" href="../adminlte/plugins/summernote/summernote-bs4.min.css">
         <!-- Font Awesome -->
         <link rel="stylesheet" href="../adminlte/plugins/fontawesome-free/css/all.min.css">
    }
    else
    {
         <!-- Tempusdominus Bootstrap 4 -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css">
         <!-- iCheck -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
         <!-- JQVMap -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/jqvmap/jqvmap.min.css">
         <!-- Theme style -->
         <link rel="stylesheet" href="@localpath/adminlte/css/adminlte.min.css">
         <!-- overlayScrollbars -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/overlayScrollbars/css/OverlayScrollbars.min.css">
         <!-- Daterange picker -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/daterangepicker/daterangepicker.css">
         <!-- Summer Note -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/summernote/summernote-bs4.min.css">
         <!-- fullcalendar -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/fullcalendar/main.css" />
         <!-- Font Awesome -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/fontawesome-free/css/all.min.css">
         <!-- DataTables -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
         <link rel="stylesheet" href="@localpath/adminlte/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
         <link rel="stylesheet" href="@localpath/adminlte/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
         <!-- SweetAlert2 -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/sweetalert2-theme-bootstrap-4/bootstrap-4.min.css">
         <!-- Toastr -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/toastr/toastr.min.css">
         <!-- BootStrap-fs-modal -->
         <link rel="stylesheet" href="@localpath/adminlte/plugins/bootstrap-fs-modal/css/bootstrap-fs-modal.css">
    }
}

</head>
